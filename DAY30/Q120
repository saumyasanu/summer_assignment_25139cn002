/* Mini Project: Student Record System */

#include <stdio.h>

void input(int roll[], char name[][20], int marks[], int n);
void display(int roll[], char name[][20], int marks[], int n);

int main()
{
    int roll[10], marks[10], n;

    char name[10][20];

    printf("Enter number of students: ");
    scanf("%d", &n);

    input(roll, name, marks, n);
    display(roll, name, marks, n);

    return 0;
}

void input(int roll[], char name[][20], int marks[], int n)
{
    int i;

    for(i = 0; i < n; i++)
    {
        printf("\nEnter details of Student %d\n", i + 1);

        printf("Roll Number: ");
        scanf("%d", &roll[i]);

        printf("Name: ");
        scanf("%s", name[i]);

        printf("Marks: ");
        scanf("%d", &marks[i]);
    }
}

void display(int roll[], char name[][20], int marks[], int n)
{
    int i;

    printf("\n--- Student Records ---\n");

    for(i = 0; i < n; i++)
    {
        printf("\nRoll Number: %d", roll[i]);
        printf("\nName: %s", name[i]);
        printf("\nMarks: %d\n", marks[i]);
    }
}
