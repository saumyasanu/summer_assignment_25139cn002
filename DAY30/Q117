/* Student Record System using Arrays and Strings */

#include <stdio.h>

int main()
{
    int roll[10], marks[10], n, i;
    char name[10][30];

    printf("Enter number of students: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
    {
        printf("\nEnter details of Student %d\n", i + 1);

        printf("Roll Number: ");
        scanf("%d", &roll[i]);

        printf("Name: ");
        scanf("%s", name[i]);

        printf("Marks: ");
        scanf("%d", &marks[i]);
    }

    printf("\n--- Student Records ---\n");

    for(i = 0; i < n; i++)
    {
        printf("\nRoll Number: %d", roll[i]);
        printf("\nName: %s", name[i]);
        printf("\nMarks: %d\n", marks[i]);
    }

    return 0;
}
