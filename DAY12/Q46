//Program to check whether a number is Armstrong or not using a function

#include <stdio.h>

/* Function Declaration */
int armstrong(int);

int main()
{
    int num;

    printf("Enter a number: ");
    scanf("%d", &num);

    if (armstrong(num))
        printf("%d is an Armstrong Number.", num);
    else
        printf("%d is not an Armstrong Number.", num);

    return 0;
}

/* Function Definition */
int armstrong(int n)
{
    int original, rem, sum = 0;

    original = n;

    while (n != 0)
    {
        rem = n % 10;
        sum = sum + (rem * rem * rem);
        n = n / 10;
    }

    if (original == sum)
        return 1;
    else
        return 0;
}
