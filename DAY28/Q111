/* Ticket Booking System */

#include <stdio.h>

int main()
{
    char name[50];
    int tickets;
    int price = 100;
    int total;

    printf("Enter Customer Name: ");
    scanf("%s", name);

    printf("Enter Number of Tickets: ");
    scanf("%d", &tickets);

    total = tickets * price;

    printf("\n--- Ticket Details ---\n");
    printf("Customer Name: %s\n", name);
    printf("Tickets Booked: %d\n", tickets);
    printf("Total Amount: %d\n", total);

    return 0;
}
