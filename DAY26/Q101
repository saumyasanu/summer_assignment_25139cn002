// Number Guessing Game //

#include <stdio.h>

int main()
{
    int secret = 25, guess;

    printf("Guess a number between 1 and 50:\n");

    do
    {
        printf("Enter your guess: ");
        scanf("%d", &guess);

        if(guess > secret)
            printf("Too High!\n");
        else if(guess < secret)
            printf("Too Low!\n");
        else
            printf("Congratulations! You guessed the correct number.\n");

    } while(guess != secret);

    return 0;
}
